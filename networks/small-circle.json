{
  "name": "small-circle",
  "join_rule": "open",
  "expr_policy": {
    "version": 1,
    "rules": [
      {
        "name": "earn",
        "on": "datagram",
        "match": "true",
        "actions": [
          {
            "type": "allow"
          }
        ]
      },
      {
        "name": "trim",
        "on": "cycle",
        "match": "trusted_count > 50",
        "actions": [
          {
            "type": "prune_trust",
            "params": {
              "percent": 15,
              "min": 50
            }
          }
        ]
      },
      {
        "name": "fill",
        "on": "cycle",
        "match": "trusted_count < 50",
        "actions": [
          {
            "type": "fill_trust",
            "params": {
              "target": 50
            }
          }
        ]
      }
    ],
    "config": {
      "cycle": "6h"
    }
  },
  "policy": {
    "description": "Small circle: hard-capped at 50 members, refilled every 6h — a tight clique where the lowest-engagement 15% are rotated out frequently."
  }
}
