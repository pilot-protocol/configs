{
  "name": "cold-shoulder",
  "join_rule": "open",
  "expr_policy": {
    "version": 1,
    "rules": [
      {
        "name": "reset",
        "on": "cycle",
        "match": "true",
        "actions": [
          {
            "type": "fill_trust",
            "params": {
              "target": 0
            }
          }
        ]
      }
    ],
    "config": {
      "cycle": "12h"
    }
  },
  "policy": {
    "description": "Cold shoulder: every 12h cycle clears all trusted peers (fill_trust target=0), forcing a full re-evaluation of who belongs."
  }
}
