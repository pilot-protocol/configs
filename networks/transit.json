{
  "name": "transit",
  "join_rule": "open",
  "policy": {
    "description": "Public-transit schedules, real-time arrivals and network status. Open inter-agent communication."
  },
  "expr_policy": {
    "version": 1,
    "default_verdict": "allow",
    "rules": [
      {
        "name": "open-connect",
        "on": "connect",
        "match": "true",
        "actions": [{"type": "allow"}]
      },
      {
        "name": "open-dial",
        "on": "dial",
        "match": "true",
        "actions": [{"type": "allow"}]
      },
      {
        "name": "open-datagram",
        "on": "datagram",
        "match": "true",
        "actions": [{"type": "allow"}]
      }
    ]
  }
}
