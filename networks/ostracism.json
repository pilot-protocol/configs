{
  "name": "ostracism",
  "join_rule": "open",
  "expr_policy": {
    "version": 1,
    "rules": [
      {
        "name": "tag-on-deny",
        "on": "datagram",
        "match": "true",
        "actions": [
          {"type": "log", "params": {"message": "datagram evaluated", "level": "debug"}}
        ]
      },
      {
        "name": "cycle-prune",
        "on": "cycle",
        "match": "true",
        "actions": [
          {"type": "evict_where", "params": {"match": "has_tag(peer_tags, \"ostracized\")"}}
        ]
      }
    ]
  },
  "policy": {
    "description": "Ostracism: peers tagged ostracized are banished on the next 6h cycle."
  }
}
