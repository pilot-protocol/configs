{
  "name": "two-strikes",
  "join_rule": "open",
  "expr_policy": {
    "version": 1,
    "rules": [
      {
        "name": "log-activity",
        "on": "datagram",
        "match": "true",
        "actions": [
          {"type": "log", "params": {"message": "datagram evaluated", "level": "debug"}}
        ]
      },
      {
        "name": "cycle-evict-flagged",
        "on": "cycle",
        "match": "true",
        "actions": [
          {"type": "evict_where", "params": {"match": "has_tag(peer_tags, \"two-strikes\")"}},
          {"type": "fill", "params": {"count": 5, "how": "random"}}
        ]
      }
    ]
  },
  "policy": {
    "description": "Two strikes: peers tagged two-strikes are evicted on the next 12h cycle."
  }
}
