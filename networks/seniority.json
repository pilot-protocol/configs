{
  "name": "seniority",
  "join_rule": "open",
  "expr_policy": {
    "version": 1,
    "rules": [
      {
        "name": "open-talk",
        "on": "datagram",
        "match": "true",
        "actions": [
          {
            "type": "allow"
          }
        ]
      },
      {
        "name": "dial-elders",
        "on": "dial",
        "match": "peer_age_s >= 86400",
        "actions": [
          {
            "type": "allow"
          }
        ]
      },
      {
        "name": "dial-young",
        "on": "dial",
        "match": "true",
        "actions": [
          {
            "type": "deny"
          }
        ]
      }
    ],
    "config": {
      "cycle": "24h"
    }
  },
  "policy": {
    "description": "Seniority rules: every cycle all peers gain +1 score just from existing, but only peers older than 24h may initiate dials."
  }
}
