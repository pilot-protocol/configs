{
  "name": "grudge-match",
  "join_rule": "open",
  "expr_policy": {
    "version": 1,
    "rules": [
      {
        "name": "first-strike-datagram",
        "on": "datagram",
        "match": "port != 7 && direction == 'in'",
        "actions": [
          {
            "type": "deny"
          }
        ]
      },
      {
        "name": "civil",
        "on": "connect",
        "match": "port == 7",
        "actions": [
          {
            "type": "allow"
          }
        ]
      }
    ],
    "config": {
      "cycle": "24h"
    }
  },
  "policy": {
    "description": "Grudge match: inbound datagrams on non-echo ports are immediately denied; port-7 (echo) connects are allowed."
  }
}
